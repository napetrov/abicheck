{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "timezone": "America/Los_Angeles",
  "schedule": ["before 9am on Monday"],
  "labels": ["dependencies"],
  "prConcurrentLimit": 5,
  "prHourlyLimit": 2,
  "packageRules": [
    {
      "description": "Group all GitHub Actions updates into a single PR",
      "matchManagers": ["github-actions"],
      "groupName": "GitHub Actions",
      "automerge": false
    },
    {
      "description": "Group Python dev/test dependency updates (PEP 621 optional-dependencies)",
      "matchManagers": ["pep621"],
      "matchDepTypes": ["project.optional-dependencies", "dependency-groups"],
      "groupName": "Python dev dependencies",
      "automerge": false
    },
    {
      "description": "Group Python runtime dependency updates (PEP 621)",
      "matchManagers": ["pep621"],
      "matchDepTypes": ["project.dependencies", "build-system.requires"],
      "groupName": "Python dependencies",
      "automerge": false
    },
    {
      "description": "Automerge minor/patch pre-commit hook updates",
      "matchManagers": ["pre-commit"],
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "pre-commit hooks",
      "automerge": true,
      "automergeType": "pr",
      "platformAutomerge": true
    }
  ],
  "vulnerabilityAlerts": {
    "enabled": true,
    "labels": ["security"]
  }
}
